{
  "manifest_version": 3,
  "name": "Realworks → n8n Sync",
  "version": "1.1",
  "description": "Synchroniseert contacten van Realworks naar n8n en voert terugschrijftaken uit via de wachtrij-API.",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://crm.realworks.nl/*",
    "https://automation.devreemakelaardij.nl/*",
    "https://kantoor.devreemakelaardij.nl/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://crm.realworks.nl/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://crm.realworks.nl/*"]
    }
  ]
}
