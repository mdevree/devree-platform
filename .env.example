# Database
DATABASE_URL="mysql://user:password@localhost:3306/devree_platform"
DEBITEUREN_API_URL="https://debiteuren.devreemakelaardij.nl"
DEBITEUREN_API_TOKEN="zelfde-lange-token-als-in-debiteuren-config"
NEXT_PUBLIC_DEBITEUREN_URL="https://debiteuren.devreemakelaardij.nl"
TZ="Europe/Amsterdam"

# Documenso / ondertekenen.devreemakelaardij.nl
DOCUMENSO_URL="https://ondertekenen.devreemakelaardij.nl"
# Interne API-url vanuit de platformcontainer op dezelfde server
DOCUMENSO_API_URL="http://127.0.0.1:3800"
DOCUMENSO_API_TOKEN=""
DOCUMENSO_ATTACHMENT_PUBLIC_BASE_URL="https://kantoor.devreemakelaardij.nl"
DOCUMENSO_REDIRECT_URL="https://www.devreemakelaardij.nl/bedankt-voor-uw-akkoord/"
PROPOSAL_PUBLIC_BASE_URL="https://www.devreemakelaardij.nl"
# Vaste bijlagen uit het Documenso OTD-verkooptemplate: ACV + Protocol Transparant Bieden
DOCUMENSO_OTD_ATTACHMENT_ITEM_IDS="envelope_item_voenxhxtymcfmfti,envelope_item_ckdzuncvzlhmnahm"
DOCUMENSO_OTD_ATTACHMENT_URLS="https://www.devreemakelaardij.nl/wp-content/uploads/2026/07/algemene-consumentenvoorwaarden-makelaardij.pdf,https://www.devreemakelaardij.nl/wp-content/uploads/2026/07/nvm-protocol-transparant-bieden-woonruimte.pdf"

# NextAuth
NEXTAUTH_SECRET="genereer-een-veilige-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Mautic CRM
MAUTIC_URL="https://connect.devreemakelaardij.nl"
MAUTIC_CLIENT_ID=""
MAUTIC_CLIENT_SECRET=""
# n8n Automation
N8N_URL="https://automation.devreemakelaardij.nl"
N8N_WEBHOOK_SECRET="gedeeld-secret-voor-webhook-verificatie"

# Fridu Radar verrijking voor buurtdata-rapporten (server-side, optioneel)
FRIDU_RADAR_API_URL="https://radar.fridu.nl/api/v1/radar.php"
FRIDU_RADAR_API_KEY=""
FRIDU_RADAR_TIMEOUT_MS="4500"

# Webhook URL voor gesprek notities (optioneel, bijv. n8n workflow)
CALL_NOTE_WEBHOOK_URL=""

# Webhook URL voor cheat-sheet generatie (n8n workflow "Cheatsheet Bezichtiging")
CHEATSHEET_WEBHOOK_URL=""
# Basis-URL van dit platform (voor absolute context-URL naar n8n; valt anders
# terug op de request-origin)
PLATFORM_BASE_URL=""

# Cheatsheet PDF-generatie & opslag (gebruikt door de n8n-workflow, niet door
# de Next.js-app zelf). Op de n8n-host configureren:
#   GOTENBERG_URL        — basis-URL van de Gotenberg-service (HTML→PDF)
#   NEXTCLOUD_URL        — basis-URL van Nextcloud
#   NEXTCLOUD_USER       — Nextcloud-gebruiker waaronder de PDF's landen
#   NEXTCLOUD_APP_PASSWORD — Nextcloud app-wachtwoord (geen accountwachtwoord)
#   NEXTCLOUD_BASE_PATH  — hoofdmap voor cheatsheets (default "Bezichtigingen")
GOTENBERG_URL="http://gotenberg:3000"
NEXTCLOUD_URL="https://cloud.devreemakelaardij.nl"
NEXTCLOUD_USER="devree"
NEXTCLOUD_APP_PASSWORD=""
NEXTCLOUD_BASE_PATH="Bezichtigingen"

# Debiteuren systeem (externe link)
DEBITEUREN_URL="https://debiteuren.devreemakelaardij.nl"

# WordPress API (Application Password voor schrijftoegang)
# Aanmaken via: WordPress > Gebruikers > Profiel > Applicatiewachtwoorden
WP_API_USER="gebruikersnaam"
WP_API_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# WhatsApp provider: "evolution" of "waha"
WHATSAPP_PROVIDER="evolution"
WHATSAPP_WEBHOOK_SECRET="zelf-kiezen-random-string"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="https://wa.devreemakelaardij.nl"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE="devree"
EVOLUTION_WEBHOOK_SECRET="zelf-kiezen-random-string"

# WAHA API (WhatsApp alternatief)
WAHA_API_URL="http://127.0.0.1:3102"
WAHA_API_KEY=""
WAHA_SESSION="default"

# Zet op 1 om inkomende WhatsApp-webhooks gestructureerd te loggen (diagnose)
WHATSAPP_WEBHOOK_DEBUG=""

# n8n WhatsApp samenvatting workflow
N8N_WEBHOOK_WHATSAPP_SUMMARY_URL="https://automation.devreemakelaardij.nl/webhook/whatsapp-summary"

# Digitale medewerker caller/resultaat webhooks (legacy n8n paths heten nog ai-belassistent)
# Start pas na menselijke goedkeuring vanuit het platform.
AI_CALL_START_WEBHOOK_URL="https://automation.devreemakelaardij.nl/webhook/ai-belassistent/start"
AI_INFO_EMAIL_WEBHOOK_URL="https://automation.devreemakelaardij.nl/webhook/ai-belassistent/info-email"

# Publieke Mautic URL (voor contact-links in de UI)
NEXT_PUBLIC_MAUTIC_URL="https://connect.devreemakelaardij.nl"

# Publieke URL van dit platform (voor WordPress shortcode iframe src)
# Voorbeeld: https://platform.devreemakelaardij.nl
NEXT_PUBLIC_PLATFORM_URL="https://platform.devreemakelaardij.nl"
PLATFORM_INTERNAL_URL="http://127.0.0.1:3100"
