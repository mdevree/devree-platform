generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProjectType {
  VERKOOP
  AANKOOP
  TAXATIE
}

enum ProjectStatus {
  LEAD
  GESPREK_GEPLAND
  OFFERTE_VERSTUURD
  OTD_VERSTUURD
  OTD_ONDERTEKEND
  ACTIEF
  LIVE_FUNDA
  ONDER_BOD
  KOOPAKTE
  GEPASSEERD
  AFGEROND
  GEANNULEERD
  RAPPORT_CONCEPT
}

enum Verkoopstart {
  DIRECT
  UITGESTELD
  SLAPEND
}

enum Verkoopmethode {
  INSCHRIJVING_MET_BIEDTERMIJN
  GESLOTEN_INSCHRIJVING_MET_BIEDTERMIJN
  OPEN_VEILING_MET_BIEDTERMIJN
  BIEDEN_ZONDER_BIEDTERMIJN
}

enum LeadStatus {
  KIJKER
  ZOEKER
  CONVERTED
  INACTIEF
}

enum LeadSource {
  WEBSITE
  SOCIAL
  TELEFOON
  EMAIL
  DOORVERWIJZING
  HANDMATIG
  API
}

enum LeadPrioriteit {
  LAAG
  NORMAAL
  HOOG
  URGENT
}

enum NewsletterItemStatus {
  INBOX
  GEPLAND
  GEBRUIKT
  GEARCHIVEERD
}

enum NewsletterIssueStatus {
  DRAFT
  READY
  EXPORTED
}

enum NewsletterBlockType {
  HERO
  TEXT
  LINK_LIST
  CTA
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  password      String
  role          String             @default("makelaar") // manager, makelaar, binnendienst
  active        Boolean            @default(true)
  assignedTasks Task[]             @relation("assignee")
  createdTasks  Task[]             @relation("creator")
  feedbackItems PlatformFeedback[] @relation("feedbackReporter")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("users")
}

model Project {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text

  // Type en status
  type          ProjectType    @default(VERKOOP)
  projectStatus ProjectStatus? // tijdelijk nullable voor migratie; wordt na data-migratie gevuld
  status        String         @default("lead") // legacy — blijft staan totdat migratie compleet is

  // Verkoopstart (alleen relevant bij type=VERKOOP)
  verkoopstart Verkoopstart?
  startdatum   DateTime?
  startReden   String?

  // Legacy velden (bewaren voor backward-compat)
  address         String?
  notionPageId    String? @unique
  mauticContactId Int? // Fallback voor backward-compat (legacy)
  realworksId     String? // Publieke objectcode (bijv. SE11902), voor WordPress/agenda
  realworksSystemId        String? // Interne Realworks _systemid van broker.brokerobject
  realworksProjectSystemId String? // Interne Realworks project_systemid
  contactName     String? // Fallback contactnaam (legacy)
  contactPhone    String? // Fallback telefoonnummer (legacy)
  contactEmail    String? // Fallback emailadres (legacy)

  // Woning velden
  woningAdres       String?
  woningPostcode    String?
  woningPlaats      String?
  kadGemeente       String?
  kadSectie         String?
  kadNummer         String?
  kadGrootte        String?
  woningOppervlakte String?

  // Commercieel
  vraagprijs          Int?
  courtagePercentage  Float?
  aanvaarding         String?
  verkoopmethode      Verkoopmethode?
  bijzondereAfspraken String?         @db.Text

  // Kosten
  kostenPubliciteit  Int?
  kostenEnergielabel Int?
  kostenJuridisch    Int?
  kostenBouwkundig   Int?
  kostenIntrekking   Int?
  kostenBedenktijd   Int?

  // Aankooptarieven (alleen type=AANKOOP; null = platformdefault)
  aankoopTariefVast           Int?
  aankoopToeslagExtraWoning   Int?
  aankoopMaxWoningen          Int?
  aankoopKostenNietDoorzetten Int?
  aankoopWerkgebied           String? @db.Text

  // Relaties
  contacts            ProjectContact[]
  proposals           ProjectProposal[]
  debiteurenLink      ProjectDebiteurenLink?
  debiteurenInvoices  ProjectDebiteurenInvoice[]
  tasks               Task[]
  taxatieMailArchives TaxatieMailArchive[]
  calls               Call[]
  leadProjecten       LeadProject[]
  facebookTriggers    FacebookTrigger[]
  agendaAfspraken     AgendaAfspraak[]
  hypotheekAdviseur   HypotheekAdviseur?     @relation(fields: [hypotheekAdviseurId], references: [id])
  hypotheekAdviseurId String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([status])
  @@index([projectStatus])
  @@index([type])
  @@index([notionPageId])
  @@index([mauticContactId])
  @@index([realworksId])
  @@index([realworksSystemId])
  @@index([realworksProjectSystemId])
  @@index([hypotheekAdviseurId])
  @@map("projects")
}

model ProjectProposal {
  id                   String        @id @default(cuid())
  project              Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            String
  events               ProjectProposalEvent[]
  tokenHash            String        @unique
  publicUrl            String?       @db.Text
  status               String        @default("OPEN") // OPEN, ACCEPTED, REVOKED, ERROR
  selectedVerkoopstart Verkoopstart?
  selectedStartdatum   DateTime?
  selectedStartReden   String?
  selectedSilentSale    Boolean?
  selectedRemarks       String?       @db.Text
  selectedEnergielabelChoice String?
  selectedEnergielabelNote   String?       @db.Text
  selectedQuickscanChoice    String?
  selectedQuickscanNote      String?       @db.Text
  documensoDocumentId  Int?
  documensoEnvelopeId  String?
  documensoSigningUrl  String?       @db.Text
  errorMessage         String?       @db.Text
  expiresAt            DateTime?
  viewedAt             DateTime?
  lastViewedAt         DateTime?
  viewCount            Int           @default(0)
  acceptedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([expiresAt])
  @@map("project_proposals")
}

model ProjectProposalEvent {
  id              String          @id @default(cuid())
  proposal        ProjectProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposalId      String
  eventType       String
  sessionId       String?
  activeSeconds   Int?
  path            String?         @db.Text
  referrer        String?         @db.Text
  userAgent       String?         @db.Text
  ipHash          String?
  viewport        String?
  createdAt       DateTime        @default(now())

  @@index([proposalId])
  @@index([eventType])
  @@index([sessionId])
  @@index([createdAt])
  @@map("project_proposal_events")
}

model ProjectContact {
  id              String   @id @default(cuid())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  mauticContactId Int
  role            String   @default("opdrachtgever") // opdrachtgever, partner, gemachtigde, overig
  label           String?
  addedAt         DateTime @default(now())
  addedBy         String?

  @@unique([projectId, mauticContactId])
  @@index([projectId])
  @@index([mauticContactId])
  @@map("project_contacts")
}

model ProjectDebiteurenLink {
  id                String    @id @default(cuid())
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId         String    @unique
  debiteurenKlantId Int
  klantNaam         String?
  klantEmail        String?
  klantAdres        String?
  mauticContactId   Int?
  contactWarnings   Json?
  normalizationCheckedAt DateTime?
  contactWarningsReviewedAt DateTime?
  contactWarningsReviewedBy String?
  contactWarningsReviewNote String?   @db.Text
  linkedBy          String?
  linkedAt          DateTime  @default(now())
  lastCheckedAt     DateTime?

  @@index([debiteurenKlantId])
  @@index([mauticContactId])
  @@map("project_debiteuren_links")
}

model ProjectDebiteurenInvoice {
  id                  String   @id @default(cuid())
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId           String
  debiteurenKlantId   Int
  debiteurenFactuurId Int
  factuurnummer       Int?
  invoiceType         String   @default("taxatie")
  subject             String?  @db.Text
  invoiceDate         DateTime?
  dueDate             DateTime?
  amountExclCents     Int
  amountInclCents     Int
  hash                String?
  idempotencyKey      String   @unique
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([projectId])
  @@index([debiteurenKlantId])
  @@index([debiteurenFactuurId])
  @@map("project_debiteuren_invoices")
}

model Call {
  id                String     @id @default(cuid())
  callId            String     @unique
  timestamp         DateTime
  status            String // ringing, in-progress, ended
  reason            String? // completed, no-answer, busy, cancelled
  direction         String // inbound, outbound
  callerNumber      String
  callerName        String?
  destinationNumber String
  destinationUser   String?
  mauticContactId   Int?
  contactName       String?
  points            Int        @default(0)
  project           Project?   @relation(fields: [projectId], references: [id])
  projectId         String?
  notes             CallNote[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([timestamp])
  @@index([callerNumber])
  @@index([mauticContactId])
  @@index([projectId])
  @@map("calls")
}

model CallNote {
  id        String   @id @default(cuid())
  call      Call     @relation(fields: [callId], references: [id])
  callId    String
  note      String   @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([callId])
  @@map("call_notes")
}

model AiCallJob {
  id               String    @id @default(cuid())
  source           String    @default("bezichtiging") // bezichtiging | kans | zoeker | manual
  agendaAfspraakId String?
  projectId        String?
  mauticContactId  Int?
  leadId           String?
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  language         String    @default("nl")
  propertyTitle    String?
  propertyAddress  String?
  propertyUrl      String?   @db.Text
  viewingDate      DateTime?
  context          Json?
  scriptPreview    String?   @db.LongText
  status           String    @default("draft") // draft | ready | approved | calling | completed | failed | cancelled
  reviewNotes      String?   @db.Text
  reviewedBy       String?
  startedBy        String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([source])
  @@index([agendaAfspraakId])
  @@index([projectId])
  @@index([mauticContactId])
  @@index([leadId])
  @@index([createdAt])
  @@map("ai_call_jobs")
}

model AiCallResult {
  id                    String    @id @default(cuid())
  aiCallJobId           String
  pbxCallId             String?
  provider              String?
  contextName           String?
  durationSeconds       Int?
  outcome               String    @default("answered") // answered | voicemail | no_answer | failed
  summary               String    @db.Text
  transcript            String?   @db.LongText
  customerQuestions     Json?
  detectedOpportunities Json?
  requestedFollowUp     Json?
  proposedLinks         Json?
  audioNotes            String?   @db.Text
  qualityScore          Int?
  mauticWrittenAt       DateTime?
  infoEmailQueuedAt     DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([aiCallJobId])
  @@index([pbxCallId])
  @@index([outcome])
  @@index([createdAt])
  @@map("ai_call_results")
}

model FollowUpDraft {
  id               String    @id @default(cuid())
  channel          String // whatsapp | email
  purpose          String // woning_link | afspraak_link | verkoop | aankoop | taxatie | faq | terugbelverzoek | bezichtiging_followup
  aiCallJobId      String?
  aiCallResultId   String?
  agendaAfspraakId String? // bron-bezichtiging; idempotency-anker voor automatische concepten
  mauticContactId  Int?
  projectId        String?
  recipientName    String?
  recipientPhone   String?
  recipientEmail   String?
  subject          String?
  body             String    @db.Text
  links            Json?
  status           String    @default("draft") // draft | approved | sent | rejected | failed
  createdBy        String    @default("ai")
  reviewedBy       String?
  reviewedAt       DateTime?
  sentAt           DateTime?
  deliveryError    String?   @db.Text
  waConversationId String?
  waMessageId      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([agendaAfspraakId, purpose])
  @@index([status])
  @@index([channel])
  @@index([purpose])
  @@index([aiCallJobId])
  @@index([aiCallResultId])
  @@index([mauticContactId])
  @@index([createdAt])
  @@map("follow_up_drafts")
}

model AiLinkCatalogItem {
  id               String    @id @default(cuid())
  title            String
  url              String    @db.Text
  type             String // woning | dienst | faq | afspraak | aanbod
  source           String    @default("manual") // wordpress | manual
  language         String    @default("nl")
  intents          Json?
  active           Boolean   @default(true)
  wordpressId      Int?
  wordpressSlug    String?
  wordpressStatus  String?
  aiDescription    String?   @db.Text
  whatsappTemplate String?   @db.Text
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([type, wordpressId])
  @@index([type])
  @@index([source])
  @@index([active])
  @@index([wordpressSlug])
  @@map("ai_link_catalog")
}

model AiAgentProfile {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  displayName          String
  roleDescription      String   @db.Text
  toneOfVoice          String?  @db.Text
  basePrompt           String   @db.LongText
  rules                Json?
  forbiddenCommitments Json?
  domainVocabulary     Json?
  active               Boolean  @default(true)
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([active])
  @@index([isDefault])
  @@map("ai_agent_profiles")
}

model AiAgentTask {
  id             String   @id @default(cuid())
  slug           String   @unique
  displayName    String
  description    String   @db.Text
  goal           String   @db.Text
  channel        String   @default("call") // call | whatsapp | email | internal
  questions      Json?
  allowedActions Json?
  followUpPolicy Json?
  active         Boolean  @default(true)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active])
  @@index([channel])
  @@index([isDefault])
  @@map("ai_agent_tasks")
}

model Task {
  id             String      @id @default(cuid())
  title          String
  description    String?     @db.Text
  status         String      @default("open") // open, bezig, afgerond
  priority       String      @default("normaal") // laag, normaal, hoog, urgent
  dueDate        DateTime?
  category       String? // binnendienst, verkoop, aankoop, taxatie, administratie
  assignee       User        @relation("assignee", fields: [assigneeId], references: [id])
  assigneeId     String
  creator        User        @relation("creator", fields: [creatorId], references: [id])
  creatorId      String
  project        Project?    @relation(fields: [projectId], references: [id])
  projectId      String?
  notionPageId   String?
  completedAt    DateTime?
  // Tijdregistratie
  timerStartedAt DateTime? // null = timer gestopt, gevuld = timer loopt
  totalTimeSpent Int         @default(0) // opgetelde seconden van afgesloten sessies
  timeEntries    TimeEntry[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([projectId])
  @@map("tasks")
}

model TaxatieMailArchive {
  id                String    @id @default(cuid())
  messageId         String
  mailbox           String
  fromEmail         String?
  toEmail           String?
  subject           String?
  receivedAt        DateTime?
  project           Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId         String?
  matchStatus       String    @default("unmatched") // matched | ambiguous | unmatched
  archiveStatus     String    @default("pending") // pending | archived | review_needed | failed
  matchScore        Int?
  matchReasons      Json?
  candidates        Json?
  checklistSignals  Json?
  suggestedSubfolder String?
  suggestedStatus   String?
  nextcloudPath     String?   @db.Text
  error             String?   @db.Text
  rawPayload        Json?
  reviewedAt        DateTime?
  reviewedBy        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([messageId, mailbox])
  @@index([projectId])
  @@index([matchStatus])
  @@index([archiveStatus])
  @@index([receivedAt])
  @@map("taxatie_mail_archives")
}

model TimeEntry {
  id        String    @id @default(cuid())
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  startedAt DateTime
  stoppedAt DateTime? // null = sessie nog actief
  duration  Int       @default(0) // seconden, ingevuld bij stoppen
  createdAt DateTime  @default(now())

  @@index([taskId])
  @@map("time_entries")
}

model MauticEvent {
  id              String   @id @default(cuid())
  mauticContactId Int
  eventType       String // "email.click", "email.open", "page.hit", "form.submit"
  emailName       String?
  emailId         Int?
  clickedUrl      String?  @db.Text
  ipAddress       String?
  occurredAt      DateTime
  rawPayload      Json?
  createdAt       DateTime @default(now())

  @@index([mauticContactId])
  @@index([eventType])
  @@index([occurredAt])
  @@map("mautic_events")
}

model NewsletterItem {
  id          String               @id @default(cuid())
  title       String
  url         String?              @db.Text
  description String?              @db.Text
  category    String?
  audience    String?
  status      NewsletterItemStatus @default(INBOX)
  sourceTitle String?
  sourceHost  String?
  createdBy   String?
  blocks      NewsletterBlock[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("newsletter_items")
}

model NewsletterIssue {
  id             String                @id @default(cuid())
  name           String
  subject        String
  preheader      String?
  status         NewsletterIssueStatus @default(DRAFT)
  segmentIds     Json?
  mauticEmailId  Int?
  mauticEmailUrl String?               @db.Text
  exportedAt     DateTime?
  blocks         NewsletterBlock[]
  createdBy      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status])
  @@index([mauticEmailId])
  @@index([createdAt])
  @@map("newsletter_issues")
}

model NewsletterBlock {
  id        String              @id @default(cuid())
  issue     NewsletterIssue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId   String
  item      NewsletterItem?     @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId    String?
  type      NewsletterBlockType @default(TEXT)
  position  Int                 @default(0)
  title     String?
  body      String?             @db.Text
  url       String?             @db.Text
  ctaLabel  String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([issueId])
  @@index([itemId])
  @@index([position])
  @@map("newsletter_blocks")
}

model RealworksObjectMutation {
  id               String    @id @default(cuid())
  sourceMessageId  String
  sourceSubject    String?
  sourceDate       DateTime?
  receivedAt       DateTime  @default(now())
  mutationType     String // new | removed | price_changed | withdrawn
  mutationLabel    String
  mutationDate     DateTime?
  exchangeObjectId String
  moveUrl          String?   @db.Text
  addressRaw       String?   @db.Text
  street           String?
  houseNumber      String?
  postcode         String?
  city             String?
  objectKind       String?
  objectSubType    String?
  askingPrice      Int?
  transactionPrice Int?
  rooms            Int?
  bedrooms         Int?
  livingArea       Int?
  plotArea         Int?
  buildYear        Int?
  brokerName       String?
  brokerEmail      String?
  imageUrl         String?   @db.Text
  features         Json?
  rawText          String    @db.Text
  rawHtml          String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([sourceMessageId, exchangeObjectId, mutationType], map: "rw_mutation_message_object_type_key")
  @@index([exchangeObjectId], map: "rw_mutation_object_idx")
  @@index([mutationType], map: "rw_mutation_type_idx")
  @@index([mutationDate], map: "rw_mutation_date_idx")
  @@map("realworks_object_mutations")
}

model RealworksMutationIngestRun {
  id                   String    @id @default(cuid())
  sourceMessageId      String    @unique
  sourceSubject        String?
  sourceDate           DateTime?
  processedAt          DateTime  @default(now())
  status               String    @default("success") // success | failed
  parsed               Int       @default(0)
  created              Int       @default(0)
  updated              Int       @default(0)
  opportunitiesCreated Int       @default(0)
  opportunitiesUpdated Int       @default(0)
  opportunitiesSkipped Int       @default(0)
  error                String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status], map: "rw_mutation_ingest_status_idx")
  @@index([sourceDate], map: "rw_mutation_ingest_source_date_idx")
  @@index([processedAt], map: "rw_mutation_ingest_processed_idx")
  @@map("realworks_mutation_ingest_runs")
}

model MarketObject {
  id                  String                    @id @default(cuid())
  canonicalKey        String?                   @unique
  status              String                    @default("active") // active | removed | withdrawn
  addressRaw          String?                   @db.Text
  street              String?
  houseNumber         String?
  houseNumberAddition String?
  postcode            String?
  city                String?
  objectKind          String?
  objectSubType       String?
  askingPrice         Int?
  transactionPrice    Int?
  rooms               Int?
  bedrooms            Int?
  livingArea          Int?
  plotArea            Int?
  buildYear           Int?
  brokerName          String?
  brokerEmail         String?
  primaryImageUrl     String?                   @db.Text
  firstSeenAt         DateTime                  @default(now())
  lastSeenAt          DateTime                  @default(now())
  lastMutationAt      DateTime?
  closedAt            DateTime?
  deleteAfter         DateTime?
  sources             MarketObjectSource[]
  enrichments         MarketObjectEnrichment[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([status], map: "market_object_status_idx")
  @@index([postcode, houseNumber, houseNumberAddition], map: "market_object_address_idx")
  @@index([deleteAfter], map: "market_object_delete_after_idx")
  @@index([closedAt], map: "market_object_closed_idx")
  @@map("market_objects")
}

model MarketObjectSource {
  id             String       @id @default(cuid())
  marketObject   MarketObject @relation(fields: [marketObjectId], references: [id], onDelete: Cascade)
  marketObjectId String
  source         String // realworks | move | social_media | manual
  sourceObjectId String?
  sourceUrl      String?      @db.Text
  confidence     Float?
  rawPayload     Json?
  firstSeenAt    DateTime     @default(now())
  lastSeenAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([source, sourceObjectId], map: "market_source_object_key")
  @@index([marketObjectId], map: "market_source_market_object_idx")
  @@index([source], map: "market_source_source_idx")
  @@index([sourceObjectId], map: "market_source_object_idx")
  @@map("market_object_sources")
}

model MarketObjectEnrichment {
  id             String       @id @default(cuid())
  marketObject   MarketObject @relation(fields: [marketObjectId], references: [id], onDelete: Cascade)
  marketObjectId String
  source         String       @default("move")
  status         String       @default("pending") // pending | success | failed
  title          String?
  listingText    String?      @db.LongText
  features       Json?
