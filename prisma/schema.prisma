}

// ─── WhatsApp Inbox ───────────────────────────────────────────────────────────

enum WaStatus {
  OPEN
  CLOSED
}

enum WaDirection {
  INBOUND
  OUTBOUND
}

enum WaDeliveryStatus {
  SENT
  FAILED
}

model WaConversation {
  id              String      @id @default(cuid())
  waPhone         String
  waName          String?
  mauticContactId Int?
  status          WaStatus    @default(OPEN)
  lastMessageAt   DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  messages        WaMessage[]

  @@index([waPhone])
  @@index([status])
  @@map("wa_conversations")
}

model WaMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   WaConversation    @relation(fields: [conversationId], references: [id])
  direction      WaDirection
  body           String            @db.Text
  mediaUrl       String?
  mediaType      String?
  evolutionMsgId String?           @unique
  deliveryStatus WaDeliveryStatus?
  deliveryError  String?           @db.Text
  readAt         DateTime?
  createdAt      DateTime          @default(now())

  @@index([conversationId])
  @@map("wa_messages")
}

