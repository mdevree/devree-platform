generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProjectType {
  VERKOOP
  AANKOOP
  TAXATIE
}

enum ProjectStatus {
  LEAD
  GESPREK_GEPLAND
  OFFERTE_VERSTUURD
  OTD_VERSTUURD
  OTD_ONDERTEKEND
  ACTIEF
  LIVE_FUNDA
  ONDER_BOD
  KOOPAKTE
  GEPASSEERD
  AFGEROND
  GEANNULEERD
  RAPPORT_CONCEPT
}

enum Verkoopstart {
  DIRECT
  UITGESTELD
  SLAPEND
}

enum Verkoopmethode {
  INSCHRIJVING_MET_BIEDTERMIJN
  GESLOTEN_INSCHRIJVING_MET_BIEDTERMIJN
  OPEN_VEILING_MET_BIEDTERMIJN
  BIEDEN_ZONDER_BIEDTERMIJN
}

enum LeadStatus {
  KIJKER
  ZOEKER
  CONVERTED
  INACTIEF
}

enum LeadSource {
  WEBSITE
  SOCIAL
  TELEFOON
  EMAIL
  DOORVERWIJZING
  HANDMATIG
  API
}

enum LeadPrioriteit {
  LAAG
  NORMAAL
  HOOG
  URGENT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("makelaar") // manager, makelaar, binnendienst
  active        Boolean  @default(true)
  assignedTasks Task[]   @relation("assignee")
  createdTasks  Task[]   @relation("creator")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model Project {
  id              String           @id @default(cuid())
  name            String
  description     String?          @db.Text

  // Type en status
  type            ProjectType      @default(VERKOOP)
  projectStatus   ProjectStatus?   // tijdelijk nullable voor migratie; wordt na data-migratie gevuld
  status          String           @default("lead") // legacy — blijft staan totdat migratie compleet is

  // Verkoopstart (alleen relevant bij type=VERKOOP)
  verkoopstart    Verkoopstart?
  startdatum      DateTime?
  startReden      String?

  // Legacy velden (bewaren voor backward-compat)
  address         String?
  notionPageId    String?          @unique
  mauticContactId Int?             // Fallback voor backward-compat (legacy)
  realworksId     String?          // Koppeling met woning op WordPress via Realworks ID
  contactName     String?          // Fallback contactnaam (legacy)
  contactPhone    String?          // Fallback telefoonnummer (legacy)
  contactEmail    String?          // Fallback emailadres (legacy)

  // Woning velden
  woningAdres       String?
  woningPostcode    String?
  woningPlaats      String?
  kadGemeente       String?
  kadSectie         String?
  kadNummer         String?
  woningOppervlakte String?

  // Commercieel
  vraagprijs          Int?
  courtagePercentage  Float?
  verkoopmethode      Verkoopmethode?
  bijzondereAfspraken String?          @db.Text

  // Kosten
  kostenPubliciteit   Int?
  kostenEnergielabel  Int?
  kostenJuridisch     Int?
  kostenBouwkundig    Int?
  kostenIntrekking    Int?
  kostenBedenktijd    Int?

  // Relaties
  contacts            ProjectContact[]
  tasks               Task[]
  calls               Call[]
  leadProjecten       LeadProject[]
  facebookTriggers    FacebookTrigger[]
  agendaAfspraken     AgendaAfspraak[]
  hypotheekAdviseur   HypotheekAdviseur? @relation(fields: [hypotheekAdviseurId], references: [id])
  hypotheekAdviseurId String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([projectStatus])
  @@index([type])
  @@index([notionPageId])
  @@index([mauticContactId])
  @@index([realworksId])
  @@index([hypotheekAdviseurId])
  @@map("projects")
}

model ProjectContact {
  id              String   @id @default(cuid())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  mauticContactId Int
  role            String   @default("opdrachtgever") // opdrachtgever, partner, gemachtigde, overig
  label           String?
  addedAt         DateTime @default(now())
  addedBy         String?

  @@unique([projectId, mauticContactId])
  @@index([projectId])
  @@index([mauticContactId])
  @@map("project_contacts")
}

model Call {
  id                String   @id @default(cuid())
  callId            String   @unique
  timestamp         DateTime
  status            String   // ringing, in-progress, ended
  reason            String?  // completed, no-answer, busy, cancelled
  direction         String   // inbound, outbound
  callerNumber      String
  callerName        String?
  destinationNumber String
  destinationUser   String?
  mauticContactId   Int?
  contactName       String?
  points            Int      @default(0)
  project           Project? @relation(fields: [projectId], references: [id])
  projectId         String?
  notes             CallNote[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([timestamp])
  @@index([callerNumber])
  @@index([mauticContactId])
  @@index([projectId])
  @@map("calls")
}

model CallNote {
  id        String   @id @default(cuid())
  call      Call     @relation(fields: [callId], references: [id])
  callId    String
  note      String   @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([callId])
  @@map("call_notes")
}

model Task {
  id               String      @id @default(cuid())
  title            String
  description      String?     @db.Text
  status           String      @default("open") // open, bezig, afgerond
  priority         String      @default("normaal") // laag, normaal, hoog, urgent
  dueDate          DateTime?
  category         String?     // binnendienst, verkoop, aankoop, taxatie, administratie
  assignee         User        @relation("assignee", fields: [assigneeId], references: [id])
  assigneeId       String
  creator          User        @relation("creator", fields: [creatorId], references: [id])
  creatorId        String
  project          Project?    @relation(fields: [projectId], references: [id])
  projectId        String?
  notionPageId     String?
  completedAt      DateTime?
  // Tijdregistratie
  timerStartedAt   DateTime?   // null = timer gestopt, gevuld = timer loopt
  totalTimeSpent   Int         @default(0) // opgetelde seconden van afgesloten sessies
  timeEntries      TimeEntry[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([projectId])
  @@map("tasks")
}

model TimeEntry {
  id        String    @id @default(cuid())
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  startedAt DateTime
  stoppedAt DateTime?  // null = sessie nog actief
  duration  Int       @default(0) // seconden, ingevuld bij stoppen
  createdAt DateTime  @default(now())

  @@index([taskId])
  @@map("time_entries")
}

model MauticEvent {
  id              String   @id @default(cuid())
  mauticContactId Int
  eventType       String   // "email.click", "email.open", "page.hit", "form.submit"
  emailName       String?
  emailId         Int?
  clickedUrl      String?  @db.Text
  ipAddress       String?
  occurredAt      DateTime
  rawPayload      Json?
  createdAt       DateTime @default(now())

  @@index([mauticContactId])
  @@index([eventType])
  @@index([occurredAt])
  @@map("mautic_events")
}

model RealworksObjectMutation {
  id               String    @id @default(cuid())
  sourceMessageId  String
  sourceSubject    String?
  sourceDate       DateTime?
  receivedAt       DateTime  @default(now())
  mutationType     String    // new | removed | price_changed | withdrawn
  mutationLabel    String
  mutationDate     DateTime?
  exchangeObjectId String
  moveUrl          String?   @db.Text
  addressRaw       String?   @db.Text
  street           String?
  houseNumber      String?
  postcode         String?
  city             String?
  objectKind       String?
  objectSubType    String?
  askingPrice      Int?
  transactionPrice Int?
  rooms            Int?
  bedrooms         Int?
  livingArea       Int?
  plotArea         Int?
  buildYear        Int?
  brokerName       String?
  brokerEmail      String?
  imageUrl         String?   @db.Text
  features         Json?
  rawText          String    @db.Text
  rawHtml          String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([sourceMessageId, exchangeObjectId, mutationType], map: "rw_mutation_message_object_type_key")
  @@index([exchangeObjectId], map: "rw_mutation_object_idx")
  @@index([mutationType], map: "rw_mutation_type_idx")
  @@index([mutationDate], map: "rw_mutation_date_idx")
  @@map("realworks_object_mutations")
}

model RealworksSearcher {
  id               String   @id @default(cuid())
  searcherId       String   @unique
  type             String?
  status           String?
  reference        String?
  objectKind       String?
  relationSystemId String?
  clientName       String?
  clientEmail      String?
  clientPhone      String?
  mauticContactId  Int?
  priceMin         Int?
  priceMax         Int?
  locations        Json?
  criteria         Json?
  notes            String?  @db.Text
  raw              Json?
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status], map: "rw_searcher_status_idx")
  @@index([type], map: "rw_searcher_type_idx")
  @@index([relationSystemId], map: "rw_searcher_relation_idx")
  @@index([mauticContactId], map: "rw_searcher_mautic_idx")
  @@map("realworks_searchers")
}

model RealworksSearchResult {
  id                       String    @id @default(cuid())
  searcherId               String
  searchResultsId          String?
  exchangeObjectId         String
  exchangeObjectEntityType String?
  searchResultStatus       String?
  matchingPercentage       Float?
  dateFound                DateTime?
  dateSent                 DateTime?
  dateViewed               DateTime?
  dateContactFormClicked   DateTime?
  isLiked                  Boolean?
  objectAddress            String?
  objectCity               String?
  objectPrice              Int?
  objectUrl                String?   @db.Text
  matchedCriteria          Json?
  nonMatchedCriteria       Json?
  raw                      Json?
  lastSyncedAt             DateTime  @default(now())
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@unique([searcherId, exchangeObjectId], map: "rw_result_searcher_object_key")
  @@index([searcherId], map: "rw_result_searcher_idx")
  @@index([exchangeObjectId], map: "rw_result_object_idx")
  @@index([dateSent], map: "rw_result_sent_idx")
  @@index([dateViewed], map: "rw_result_viewed_idx")
  @@map("realworks_search_results")
}

model ActionOpportunity {
  id                 String    @id @default(cuid())
  sourceType         String    // realworks_object_match | mautic_activity | manual
  sourceKey          String    @unique
  status             String    @default("open") // open | picked_up | dismissed | done
  priority           String    @default("normal") // low | normal | high | urgent
  title              String
  reason             String    @db.Text
  suggestedAction    String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  mauticContactId    Int?
  realworksSearcherId String?
  exchangeObjectId   String?
  objectAddress      String?
  objectCity         String?
  objectPrice        Int?
  draftStatus        String?   // requested | ready | failed
  draftChannel       String?   // email | whatsapp
  draftText          String?   @db.Text
  draftRequestedAt   DateTime?
  draftCompletedAt   DateTime?
  taskId             String?
  pickedUpAt         DateTime?
  dismissedAt        DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status], map: "action_opp_status_idx")
  @@index([priority], map: "action_opp_priority_idx")
  @@index([mauticContactId], map: "action_opp_mautic_idx")
  @@index([exchangeObjectId], map: "action_opp_object_idx")
  @@index([createdAt], map: "action_opp_created_idx")
  @@map("action_opportunities")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique  // bijv. "defaults_VERKOOP"
  value     Json               // flexibele JSON waarde
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model HypotheekAdviseur {
  id        String    @id @default(cuid())
  naam      String
  bedrijf   String?
  email     String?
  telefoon  String?
  notities  String?   @db.Text
  actief    Boolean   @default(true)
  leads         Lead[]
  projecten     Project[]
  vveGesprekken VveGesprek[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("hypotheek_adviseurs")
}

model Lead {
  id                     String             @id @default(cuid())
  mauticContactId        String?
  naam                   String
  email                  String?
  telefoon               String?
  status                 LeadStatus         @default(KIJKER)
  prioriteit             LeadPrioriteit     @default(NORMAAL)
  source                 LeadSource?
  tags                   Json?              // string[]
  notities               String?            @db.Text
  hypotheekAdviseur      HypotheekAdviseur? @relation(fields: [hypotheekAdviseurId], references: [id])
  hypotheekAdviseurId    String?
  hypotheekAdviseurDatum DateTime?
  hypotheekAfgesloten    Boolean            @default(false)
  projecten              LeadProject[]
  routes                 LeadRoute[]
  agendaAfspraken        AgendaAfspraak[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([status])
  @@index([prioriteit])
  @@index([source])
  @@index([hypotheekAdviseurId])
  @@index([mauticContactId])
  @@map("leads")
}

model LeadRoute {
  id            String   @id @default(cuid())
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
  routeType     String   // "hypotheekadviseur" | "makelaar" | "extern"
  targetId      String?
  targetNaam    String?
  targetBedrijf String?
  notities      String?  @db.Text
  routedById    String?
  routedAt      DateTime @default(now())

  @@index([leadId])
  @@index([routeType])
  @@index([routedAt])
  @@map("lead_routes")
}

model LeadProject {
  id        String   @id @default(cuid())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  addedAt   DateTime @default(now())

  @@unique([leadId, projectId])
  @@index([leadId])
  @@index([projectId])
  @@map("lead_projects")
}

model VveGesprek {
  id                  String            @id @default(cuid())
  datum               DateTime
  naam                String
  omschrijving        String?           @db.Text
  hypotheekAdviseur   HypotheekAdviseur @relation(fields: [hypotheekAdviseurId], references: [id])
  hypotheekAdviseurId String
  createdAt           DateTime          @default(now())

  @@index([hypotheekAdviseurId])
  @@index([datum])
  @@map("vve_gesprekken")
}

model AgendaAfspraak {
  id                  String    @id @default(cuid())
  systemid            Int       @unique
  agowner             String?
  agcode              String?
  agdescr             String?
  agtype              String?
  agstatus            String?
  agbegin             DateTime?
  agend               DateTime?
  aglocation          String?
  agobjcode           String?
  agrcode             String?
  relationRelationid  String?
  employeeEmployeeid  Int?
  medewerkerFullname  String?
  agmemo              String?   @db.Text
  agintratext         String?   @db.Text
  agallday            Boolean?
  aginactive          Boolean?
  alastupd            String?   // raw Realworks waarde, gebruikt voor wijzigingsdetectie
  gcalEventId         String?   // Google Calendar event ID
  gcalSyncedAt        DateTime?
  // Enrichment velden (gevuld via "Meer info" knop)
  contactNaam         String?
  contactEmail        String?
  contactTelefoon     String?
  mauticContactId     Int?
  project             Project?  @relation(fields: [projectId], references: [id])
  projectId           String?
  enrichedAt          DateTime?
  enrichmentStatus    String?   // "ok" | "partial" | "no_contact" | "no_project" | "error"
  // Brug naar het kijker-systeem: gekoppelde Lead (kijker)
  lead                Lead?     @relation(fields: [leadId], references: [id])
  leadId              String?
  // Cheatsheet/PDF tracking (n8n → Nextcloud)
  cheatsheetStatus      String?   // "gevraagd" | "gegenereerd" | "mislukt" | "verwerkt"
  cheatsheetPath        String?   // Nextcloud WebDAV-pad
  cheatsheetUrl         String?   // optionele directe (share)link
  cheatsheetGeneratedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([agbegin])
  @@index([agobjcode])
  @@index([agowner])
  @@index([projectId])
  @@index([leadId])
  @@map("agenda_afspraken")
}

model FacebookTrigger {
  id        String   @id @default(cuid())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?
  postId    String?
  keyword   String
  dmTekst   String   @db.Text
  actief    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([projectId])
  @@map("facebook_triggers")
}

// ─── WhatsApp Inbox ───────────────────────────────────────────────────────────

enum WaStatus {
  OPEN
  CLOSED
}

enum WaDirection {
  INBOUND
  OUTBOUND
}

enum WaDeliveryStatus {
  SENT
  FAILED
}

model WaConversation {
  id              String       @id @default(cuid())
  waPhone         String
  waName          String?
  mauticContactId Int?
  status          WaStatus     @default(OPEN)
  lastMessageAt   DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  messages        WaMessage[]

  @@index([waPhone])
  @@index([status])
  @@map("wa_conversations")
}

model WaMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   WaConversation @relation(fields: [conversationId], references: [id])
  direction      WaDirection
  body           String         @db.Text
  mediaUrl       String?
  mediaType      String?
  evolutionMsgId String?        @unique
  deliveryStatus WaDeliveryStatus?
  deliveryError  String?        @db.Text
  readAt         DateTime?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
  @@map("wa_messages")
}

model RealworksTask {
  id                  String    @id @default(cuid())
  taskType            String    // "write_field"
  realworksRelationId String    // Realworks relatie ID (bijv. "12345")
  fieldName           String    // Realworks veldnaam (bijv. "vrij_veld_1")
  fieldValue          String    @db.Text
  status              String    @default("pending") // pending | processing | done | failed
  error               String?   @db.Text
  processedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("realworks_tasks")
}

model RealworksTaxatieTask {
  id                  String    @id @default(cuid())
  taskType            String    // "write_field"
  realworksTaxatieId  String    // Realworks taxatie systemid (bijv. "2849636")
  fieldName           String    // Realworks veldnaam (bijv. "taxverkoopvrij")
  fieldValue          String    @db.Text
  status              String    @default("pending") // pending | processing | done | failed
  error               String?   @db.Text
  processedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("realworks_taxatie_tasks")
}

model RealworksWoningTask {
  id                String    @id @default(cuid())
  taskType          String    // "write_field"
  realworksWoningId String    // Realworks object systemid (bijv. "9042120")
  fieldName         String    // Realworks veldnaam (bijv. "lissalepr")
  fieldValue        String    @db.Text
  status            String    @default("pending") // pending | processing | done | failed
  error             String?   @db.Text
  processedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("realworks_woning_tasks")
}
