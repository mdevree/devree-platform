  targetBedrijf String?
  notities      String?  @db.Text
  routedById    String?
  routedAt      DateTime @default(now())

  @@index([leadId])
  @@index([routeType])
  @@index([routedAt])
  @@map("lead_routes")
}

model LeadProject {
  id        String   @id @default(cuid())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  addedAt   DateTime @default(now())

  @@unique([leadId, projectId])
  @@index([leadId])
  @@index([projectId])
  @@map("lead_projects")
}

model VveGesprek {
  id                  String            @id @default(cuid())
