        "mode": "runOnceForEachItem",
        "jsCode": "const searchResult = $input.item.json;\nconst originalData = $('Code in JavaScript').first().json;\n\nconst contactExists = searchResult && searchResult.id ? true : false;\nconst mauticContactId = contactExists ? searchResult.id : null;\n\nreturn {\n  json: {\n    ...originalData,\n    _contactExists: contactExists,\n    _mauticContactId: mauticContactId\n  }\n};"
