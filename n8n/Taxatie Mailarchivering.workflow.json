        "jsCode": "const match = $json;\nconst mail = $('Normaliseer taxatiemail').item.json;\nconst candidates = (match.candidates || []).map(c => `- ${c.name} (${c.score}): ${c.reasons.join(', ')}`).join('\\n') || 'Geen kandidaten';\nreturn [{ json: { action: 'create', title: `Controleer taxatiemail: ${mail.subject || mail.messageId}`, description: [`Taxatiemail kon niet automatisch worden gekoppeld.`, ``, `Status: ${match.status}`, `Mailbox: ${mail.mailbox}`, `Van: ${mail.from}`, `Onderwerp: ${mail.subject}`, ``, `Kandidaten:`, candidates, ``, `Open platform: ${match.reviewUrl}`].join('\\n'), priority: 'hoog', category: 'taxatie', assigneeEmail: 'info@devreemakelaardij.nl' } }];"
