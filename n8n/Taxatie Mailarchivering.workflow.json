    {
      "parameters": {
        "jsCode": "const match = $json;\nconst mailItem = $('Normaliseer taxatiemail').item;\nconst binary = mailItem.binary || {};\nconst mail = mailItem.json;\nconst stamp = new Date(mail.receivedAt || Date.now()).toISOString().replace(/[:T]/g, '-').slice(0, 16);\nconst idPart = String(mail.messageId || match.archiveId).replace(/[^a-zA-Z0-9]+/g, '').slice(0, 10);\nconst clean = (name) => String(name || 'bijlage.pdf').replace(/[\\\\/:*?\"<>|]+/g, ' ').replace(/\\s+/g, ' ').trim();\nconst items = [];\nfor (const [key, value] of Object.entries(binary)) {\n  const fileName = clean(value.fileName || key);\n  const mimeType = String(value.mimeType || '').toLowerCase();\n  if (!fileName.toLowerCase().endsWith('.pdf') && mimeType !== 'application/pdf') continue;\n  items.push({\n    json: {\n      archiveId: match.archiveId,\n      nextcloudPath: `${match.selected.nextcloudBasePath}/${match.selected.targetSubfolder}/${stamp}_${idPart}_${fileName}`,\n    },\n    binary: { data: value },\n  });\n}\nreturn items;"
      },
