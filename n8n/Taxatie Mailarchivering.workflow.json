    {
      "parameters": {
        "jsCode": "const match = $json;\nconst mail = $('Normaliseer taxatiemail').item.json;\nconst esc = (v) => String(v ?? '').replace(/[&<>\"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[c]));\nconst received = mail.receivedAt ? new Date(mail.receivedAt).toLocaleString('nl-NL', { timeZone: 'Europe/Amsterdam' }) : '';\nconst body = mail.textHtml || `<pre>${esc(mail.bodyText || '')}</pre>`;\nconst html = `<!doctype html><html lang=\"nl\"><head><meta charset=\"utf-8\"><style>@page{size:A4;margin:16mm}body{font-family:Arial,sans-serif;color:#111827;font-size:12px;line-height:1.45}.meta{border:1px solid #d1d5db;border-radius:6px;padding:10px;margin-bottom:14px}.label{font-weight:700;color:#4b5563;display:inline-block;width:80px}h1{font-size:18px;margin:0 0 10px}</style></head><body><h1>${esc(mail.subject || 'Taxatiemail')}</h1><div class=\"meta\"><div><span class=\"label\">Van</span>${esc(mail.from)}</div><div><span class=\"label\">Aan</span>${esc(mail.to)}</div><div><span class=\"label\">Datum</span>${esc(received)}</div><div><span class=\"label\">Message-ID</span>${esc(mail.messageId)}</div></div>${body}</body></html>`;\nconst slug = String(mail.subject || 'taxatiemail').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 60) || 'taxatiemail';\nconst stamp = new Date(mail.receivedAt || Date.now()).toISOString().replace(/[:T]/g, '-').slice(0, 16);\nconst idPart = String(mail.messageId || match.archiveId).replace(/[^a-zA-Z0-9]+/g, '').slice(0, 10);\nconst nextcloudPath = `${match.selected.nextcloudBasePath}/${match.selected.targetSubfolder}/${stamp}_${slug}_${idPart}.pdf`;\nreturn [{ json: { archiveId: match.archiveId, nextcloudPath, match }, binary: { data: { data: Buffer.from(html).toString('base64'), mimeType: 'text/html', fileName: 'index.html' } } }];"
      },
